# ---- Telegram proxy ----
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenGoesHere
API_KEY=changeme-telegram-shared-secret

LOG_FILE=/app/logs/app.log
LOG_LEVEL=INFO

# Predefined Telegram channel/group id that receives failure/alert notifications
# (used by BOTH the telegram-proxy and the whatsapp-proxy)
ALERT_CHAT_ID=-1009876543210
ALERT_COOLDOWN_SECONDS=60

# ---- WhatsApp proxy ----
WHATSAPP_API_KEY=changeme-whatsapp-shared-secret

# How the whatsapp-proxy reaches the telegram-proxy to deliver its alerts
TELEGRAM_PROXY_URL=http://telegram-proxy:8080
TELEGRAM_PROXY_API_KEY=changeme-telegram-shared-secret   # must match API_KEY above

MAX_BUFFERED_MESSAGES=500
